MARIADB_DATABASE=inky_easel
MARIADB_USER=inky
MARIADB_PASSWORD=changeme
MARIADB_ROOT_PASSWORD=changeme-root

API_DATABASE_URL=mysql+aiomysql://inky:changeme@db:3306/inky_easel
PORTAL_DATABASE_URL=mysql://inky:changeme@db:3306/inky_easel

SERVICE_SECRET=please-generate-a-long-random-string

# Default frame-facing API origin for production bundles.
# For local hardware development, override this per bundle in the setup wizard
# with http://<your-lan-ip>:8000 instead of changing production/Coolify values.
PUBLIC_BASE_URL=https://easel.example.com
CORS_ORIGINS=https://easel.example.com

BETTER_AUTH_URL=https://easel.example.com
BETTER_AUTH_SECRET=please-generate-another-long-random-string
BETTER_AUTH_TRUSTED_ORIGINS=https://easel.example.com

API_PORT=8000
PORTAL_PORT=3000
MARIADB_PORT=3306
CONTENT_CACHE_MINUTES=15

# Required by OSM Nominatim geocoding policy — include contact email or URL
NOMINATIM_USER_AGENT=InkyEasel/1.0 (you@example.com)
