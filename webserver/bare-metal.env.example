# Copy to .env.bare-metal on your server and edit before deploying.
#
# The host ports are intentionally not 3000/8000 so this stack can coexist with
# other services. Cloudflare Tunnel should point to these localhost ports.

PORTAL_BIND_ADDRESS=127.0.0.1
PORTAL_HOST_PORT=13000

API_BIND_ADDRESS=127.0.0.1
API_HOST_PORT=18080

MARIADB_DATABASE=inky_easel
MARIADB_USER=inky
MARIADB_PASSWORD=change-this-database-password
MARIADB_ROOT_PASSWORD=change-this-root-password

API_DATABASE_URL=mysql+aiomysql://inky:change-this-database-password@db:3306/inky_easel
PORTAL_DATABASE_URL=mysql://inky:change-this-database-password@db:3306/inky_easel

SERVICE_SECRET=generate-a-long-random-service-secret

# Public URLs seen by browsers and the Inky Frame.
PUBLIC_BASE_URL=https://api.inky.taogroves.com
CORS_ORIGINS=https://inky.taogroves.com

BETTER_AUTH_URL=https://inky.taogroves.com
BETTER_AUTH_SECRET=generate-a-long-random-auth-secret
BETTER_AUTH_TRUSTED_ORIGINS=https://inky.taogroves.com

CONTENT_CACHE_MINUTES=15

# Required by OSM Nominatim geocoding policy - include contact email or URL.
NOMINATIM_USER_AGENT=InkyEasel/1.0 (you@example.com)
